        <form method="POST" action="{{ route('ingwebpay.checkout') }}">
            @csrf

            <div class="form-group">
                <label for="amount">{{ __('Amount') }} ({{ config('ingwebpay.currency') === '946' ? 'RON' : 'EUR' }})</label>
                <input type="number" id="amount" name="amount" step="0.01" min="0.01"
                       value="{{ old('amount') }}" required placeholder="0.00">
            </div>

            <div class="form-group">
                <label for="order_number">{{ __('Order Number') }}</label>
                <input type="text" id="order_number" name="order_number"
                       value="{{ old('order_number') }}" placeholder="{{ __('Optional') }}">
            </div>

            <div class="form-group">
                <label for="description">{{ __('Description') }}</label>
                <input type="text" id="description" name="description"
                       value="{{ old('description') }}" placeholder="{{ __('Optional') }}">
            </div>

            <div class="form-group">
                <label for="email">{{ __('Email') }}</label>
                <input type="email" id="email" name="email"
                       value="{{ old('email') }}" placeholder="{{ __('Optional — for payment confirmation') }}">
            </div>

            <button type="submit" class="btn">{{ __('Pay Now') }}</button>
        </form>

        <div class="secure-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
            </svg>
            {{ __('Secured by ING WebPay — ING Bank N.V. Amsterdam, Bucharest Branch') }}
