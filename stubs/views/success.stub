<!DOCTYPE html>
<html lang="{{ app()->getLocale() }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ __('Payment Successful') }} — {{ config('app.name') }}</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, sans-serif;
            background: #f4f6f8;
            color: #333;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 4px 24px rgba(0,0,0,.08);
            max-width: 480px;
            width: 100%;
            padding: 2.5rem;
            text-align: center;
        }
        .icon {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: #e6f9f0;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.25rem;
            font-size: 2rem;
        }
        .card h1 {
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
            color: #0a8754;
        }
        .card p {
            color: #666;
            margin-bottom: 1.5rem;
        }
        .details {
            text-align: left;
            background: #f9fafb;
            border-radius: 8px;
            padding: 1rem 1.25rem;
            margin-bottom: 1.5rem;
        }
        .details .row {
            display: flex;
            justify-content: space-between;
            padding: 0.4rem 0;
            font-size: 0.95rem;
        }
        .details .row .label { color: #888; }
        .details .row .value { font-weight: 600; }
        .btn {
            display: inline-block;
            padding: 0.7rem 2rem;
            background: #ff6200;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            text-decoration: none;
            transition: background .2s;
        }
        .btn:hover { background: #e65800; }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon">✅</div>
        <h1>{{ __('Payment Successful') }}</h1>
        <p>{{ __('Your payment has been processed successfully.') }}</p>

        @if ($payment)
            <div class="details">
                @if (!empty($payment['order_number']))
                    <div class="row">
                        <span class="label">{{ __('Order') }}</span>
                        <span class="value">{{ $payment['order_number'] }}</span>
                    </div>
                @endif
                @if (!empty($payment['amount']))
                    <div class="row">
                        <span class="label">{{ __('Amount') }}</span>
                        <span class="value">
                            {{ number_format($payment['amount'], 2) }}
                            {{ $payment['currency'] === '946' ? 'RON' : 'EUR' }}
                        </span>
                    </div>
                @endif
                @if (!empty($payment['pan']))
                    <div class="row">
                        <span class="label">{{ __('Card') }}</span>
                        <span class="value">{{ $payment['pan'] }}</span>
                    </div>
                @endif
                @if (!empty($payment['cardholder']))
                    <div class="row">
                        <span class="label">{{ __('Cardholder') }}</span>
                        <span class="value">{{ $payment['cardholder'] }}</span>
                    </div>
                @endif
            </div>
        @endif

        <a href="{{ url('/') }}" class="btn">{{ __('Back to Homepage') }}</a>
    </div>
</body>
</html>
